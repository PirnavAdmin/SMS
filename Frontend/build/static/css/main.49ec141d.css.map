.ay-page{width:100%;min-width:0;display:grid;gap:18px;padding:2px;color:#202a52}
.ay-card{position:relative;width:100%;min-width:0;overflow:hidden;padding:22px 26px;border:1px solid rgba(154,140,255,.28);border-radius:8px;background:rgba(255,255,255,.93);box-shadow:0 14px 32px rgba(92,105,190,.13)}
.ay-form-card{min-height:290px;isolation:isolate}
.ay-details-card{padding:18px 20px}
.ay-section-title{position:relative;z-index:1;width:fit-content;display:flex;align-items:center;gap:12px;margin-bottom:18px}
.ay-section-title h3{margin:0;font-size:18px;line-height:1.2;font-weight:800}
.ay-heading-icon{width:34px;height:34px;display:grid;place-items:center;border-radius:50%;color:#6654d9;background:#f0edff;box-shadow:0 8px 18px rgba(102,84,217,.16)}
.ay-heading-icon .ay-icon{width:18px;height:18px}
.ay-icon{width:14px;height:14px;flex:0 0 auto}
.ay-form{position:relative;z-index:1;width:min(520px,calc(100% - 360px));display:grid;grid-template-columns:minmax(240px,1fr) auto;align-items:end;gap:16px 24px}
.ay-field{display:flex;min-width:0;flex-direction:column;gap:6px}
.ay-field span,.ay-checkbox-field span,.ay-show-control,.ay-search-control{color:#283354;font-size:13px;font-weight:700}
.ay-field input,.ay-show-control select,.ay-search-control input{min-height:36px;border:1px solid #dfe3f5;border-radius:6px;padding:0 12px;background:#fff;color:#303b5e;font:inherit;outline:none;box-shadow:0 4px 12px rgba(92,105,190,.08);transition:.2s}
.ay-field input:focus,.ay-show-control select:focus,.ay-search-control input:focus{border-color:#7968ef;box-shadow:0 0 0 3px rgba(121,104,239,.16)}
.ay-checkbox-field{min-height:36px;display:flex;align-items:center;gap:9px;cursor:pointer}
.ay-checkbox-field input{width:17px;height:17px;margin:0;accent-color:#7968ef}
.ay-form-actions{grid-column:1/-1;display:flex;gap:14px;margin-top:6px}
.ay-save-button,.ay-clear-button,.ay-edit-button,.ay-delete-button,.ay-page-button{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:6px;cursor:pointer;font-weight:700;transition:transform .2s,box-shadow .2s,opacity .2s}
.ay-save-button,.ay-clear-button{min-height:40px;padding:0 20px}
.ay-save-button{min-width:118px;border:0;color:#fff;background:linear-gradient(135deg,#9868e8,#438cf0);box-shadow:0 10px 20px rgba(93,112,225,.24)}
.ay-clear-button{border:1px solid #e8ebf8;color:#626986;background:#fff;box-shadow:0 8px 16px rgba(92,105,190,.1)}
.ay-save-button:hover,.ay-clear-button:hover,.ay-edit-button:hover,.ay-delete-button:hover,.ay-page-button:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 12px 20px rgba(92,105,190,.16)}
.ay-table-tools{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:12px}
.ay-show-control,.ay-search-control{display:inline-flex;align-items:center;gap:8px}
.ay-show-control select{width:78px}.ay-search-control input{width:220px}
.ay-table-wrap{width:100%;max-height:420px;overflow:auto;border:1px solid #e8ebf8;border-radius:7px;scrollbar-width:thin;scrollbar-color:#b8adff #f5f6ff}
.ay-table{width:100%;border-collapse:collapse;color:#303b5e;table-layout:fixed}
.ay-table thead{position:sticky;top:0;z-index:1;color:#fff;background:linear-gradient(135deg,#9868e8,#438cf0)}
.ay-table th,.ay-table td{padding:12px 10px;border:0;text-align:center;font-size:13px;line-height:1.25;overflow-wrap:anywhere}
.ay-table th{font-weight:800}.ay-table tbody tr{border-bottom:1px solid #e8ebf8}.ay-table tbody tr:nth-child(even){background:#f8faff}.ay-table tbody tr:hover{background:#f0edff}
.ay-action-column{width:210px}.ay-action-buttons{display:flex;align-items:center;justify-content:center;gap:6px}
.ay-edit-button,.ay-delete-button{min-height:36px;padding:0 11px;border:0;color:#fff;font-size:12px}
.ay-edit-button{background:linear-gradient(135deg,#7968ef,#5d4fd2)}.ay-delete-button{background:linear-gradient(135deg,#ff6f85,#f54864)}
.ay-status-active,.ay-status-inactive{display:inline-block;padding:5px 11px;border-radius:999px;font-size:12px;font-weight:800}
.ay-status-active{color:#168263;background:#e7f8f1}.ay-status-inactive{color:#d3455b;background:#fff0f3}
.ay-empty{padding:25px!important;color:#667085;font-weight:700}
.ay-pagination-bar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-top:14px}.ay-pagination-bar p{margin:0;color:#4e5b7c;font-size:13px;font-weight:700}.ay-pagination-actions{display:flex;gap:8px}
.ay-page-button{min-width:42px;min-height:36px;padding:0 13px;border:1px solid #e8ebf8;background:#fff;color:#626986;box-shadow:0 8px 16px rgba(92,105,190,.1)}.ay-page-current{border-color:transparent;color:#fff;background:linear-gradient(135deg,#7968ef,#438cf0)}.ay-page-button:disabled{cursor:not-allowed;opacity:.45}
.ay-watermark{position:absolute;right:36px;top:28px;width:290px;height:230px;border-radius:48% 52% 42% 58%;background:radial-gradient(circle at 76% 16%,rgba(90,224,205,.38),transparent 11%),radial-gradient(circle at 18% 72%,rgba(255,110,139,.16),transparent 17%),linear-gradient(135deg,rgba(167,127,245,.24),rgba(255,218,138,.24));opacity:.4;filter:saturate(85%) brightness(105%) contrast(94%);pointer-events:none;z-index:0}
.ay-watermark-calendar{position:absolute;left:63px;top:43px;width:150px;height:132px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding:48px 20px 18px;border:9px solid #7968ef;border-radius:16px;background:#fff;box-shadow:0 18px 28px rgba(121,104,239,.22)}
.ay-watermark-calendar:before{content:"";position:absolute;left:-9px;right:-9px;top:25px;height:9px;background:#7968ef}.ay-watermark-calendar:after{content:"";position:absolute;left:28px;top:-18px;width:14px;height:30px;border-radius:9px;background:#7968ef;box-shadow:79px 0 #7968ef}
.ay-watermark-calendar i{border-radius:4px;background:#aaa0ff}.ay-watermark-check{position:absolute;right:25px;bottom:20px;width:62px;height:62px;display:grid;place-items:center;border-radius:50%;color:#fff;background:linear-gradient(135deg,#5ae0cd,#7968ef);font-size:38px;font-weight:900;box-shadow:0 12px 20px rgba(67,140,240,.22)}
@media(max-width:1100px){.ay-form{width:100%}.ay-watermark{display:none}}
@media(max-width:640px){.ay-card{padding:18px}.ay-form{grid-template-columns:1fr}.ay-form-actions{flex-direction:column}.ay-save-button,.ay-clear-button{width:100%}.ay-table-tools,.ay-pagination-bar{align-items:stretch;flex-direction:column}.ay-search-control input{width:100%}.ay-action-column{width:150px}.ay-action-buttons{flex-wrap:wrap}.ay-pagination-actions{justify-content:flex-end}}
