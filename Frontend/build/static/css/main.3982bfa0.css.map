  max-height: 420px;
  overflow-x: hidden;
  overflow-y: auto;
  border-color: #e8ebf8;
  scrollbar-width: thin;
  scrollbar-color: #b8adff #f5f6ff;
}

.syllabus-table-wrap::-webkit-scrollbar {
  display: block;
  width: 8px;
  height: 0;
}

.syllabus-table-wrap::-webkit-scrollbar-track {
  background: #f5f6ff;
}

.syllabus-table-wrap::-webkit-scrollbar-thumb {
  background: #b8adff;
  border-radius: 999px;
}

.syllabus-table {
  table-layout: fixed;
}

.syllabus-table th,
.syllabus-table td {
  padding: 12px 8px;
  line-height: 1.25;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.syllabus-table tbody tr {
  border-bottom-color: #e8ebf8;
}

.syllabus-table tbody tr:nth-child(even) {
  background: #f8faff;
}

.syllabus-table tbody tr:hover {
  background: #f0edff;
}

.syllabus-edit-btn {
