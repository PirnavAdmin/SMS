  flex: 0 0 auto;
}

.syllabus-form {
  position: relative;
  z-index: 1;
  width: min(860px, 100%);
}

.syllabus-field span,
.syllabus-check-field span,
.syllabus-show-control,
.syllabus-search-control {
  color: #283354;
}

.syllabus-field input,
.syllabus-field textarea,
.syllabus-search-control input,
.syllabus-show-control select {
  border-color: #dfe3f5;
  color: #303b5e;
  box-shadow: 0 4px 12px rgba(92, 105, 190, 0.08);
}

.syllabus-field input:focus,
.syllabus-field textarea:focus,
.syllabus-search-control input:focus,
.syllabus-show-control select:focus {
  border-color: #7968ef;
  box-shadow: 0 0 0 3px rgba(121, 104, 239, 0.16);
}

.syllabus-check-field input {
