}

.syllabus-delete-btn {
  background: linear-gradient(135deg, #ff6f85, #f54864);
}

.syllabus-hero-art {
  right: 38px;
  top: 28px;
  width: 290px;
  height: 230px;
  background: radial-gradient(circle at 76% 16%, rgba(90, 224, 205, 0.38), transparent 11%),
    radial-gradient(circle at 18% 72%, rgba(255, 110, 139, 0.16), transparent 17%),
    linear-gradient(135deg, rgba(167, 127, 245, 0.24), rgba(255, 218, 138, 0.24));
  z-index: 0;
  pointer-events: none;
}

.syllabus-art-book {
  top: 58px;
  width: 82px;
  height: 108px;
  border: 10px solid #7968ef;
  box-shadow: 0 18px 28px rgba(121, 104, 239, 0.22);
}

.syllabus-art-book-one {
  left: 70px;
  border-radius: 12px 3px 3px 12px;
}

.syllabus-art-book-two {
  left: 134px;
  border-radius: 3px 12px 12px 3px;
}

.syllabus-art-book::before {
  left: 18px;
  right: 18px;
  top: 30px;
  height: 9px;
  background: #aaa0ff;
  box-shadow: 0 24px 0 #5ae0cd;
}

.syllabus-art-page {
  right: 28px;
  bottom: 38px;
  width: 66px;
  height: 46px;
  border-radius: 10px;
  background: linear-gradient(135deg, #5ae0cd, #7968ef);
  box-shadow: 0 12px 20px rgba(67, 140, 240, 0.22);
}

@media (max-width: 1100px) {
  .syllabus-form {
    width: 100%;
  }

  .syllabus-hero-art {
    display: none;
  }
}
