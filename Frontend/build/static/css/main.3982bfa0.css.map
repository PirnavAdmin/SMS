.bt-page{width:100%;min-width:0;display:grid;gap:18px;padding:2px;color:#202a52}.bt-card{position:relative;width:100%;min-width:0;overflow:hidden;padding:22px 26px;border:1px solid rgba(154,140,255,.28);border-radius:8px;background:rgba(255,255,255,.93);box-shadow:0 14px 32px rgba(92,105,190,.13)}.bt-form-card{min-height:290px;isolation:isolate}.bt-details-card{padding:18px 20px}.bt-section-title{position:relative;z-index:1;width:fit-content;display:flex;align-items:center;gap:12px;margin-bottom:18px}.bt-section-title h3{margin:0;font-size:18px;line-height:1.2;font-weight:800}.bt-heading-icon{width:34px;height:34px;display:grid;place-items:center;border-radius:50%;color:#6654d9;background:#f0edff;box-shadow:0 8px 18px rgba(102,84,217,.16)}.bt-heading-icon .bt-icon{width:19px;height:19px}.bt-icon{width:14px;height:14px;flex:0 0 auto}.bt-form{position:relative;z-index:1;width:min(520px,calc(100% - 360px));display:grid;grid-template-columns:minmax(240px,1fr) auto;align-items:end;gap:16px 24px}.bt-field{display:flex;min-width:0;flex-direction:column;gap:6px}.bt-field span,.bt-checkbox-field span,.bt-show-control,.bt-search-control{color:#283354;font-size:13px;font-weight:700}.bt-field input,.bt-show-control select,.bt-search-control input{min-height:36px;border:1px solid #dfe3f5;border-radius:6px;padding:0 12px;background:#fff;color:#303b5e;font:inherit;outline:none;box-shadow:0 4px 12px rgba(92,105,190,.08);transition:.2s}.bt-field input:focus,.bt-show-control select:focus,.bt-search-control input:focus{border-color:#7968ef;box-shadow:0 0 0 3px rgba(121,104,239,.16)}.bt-checkbox-field{min-height:36px;display:flex;align-items:center;gap:9px;cursor:pointer}.bt-checkbox-field input{width:17px;height:17px;margin:0;accent-color:#7968ef}.bt-form-actions{grid-column:1/-1;display:flex;gap:14px;margin-top:6px}.bt-save-button,.bt-clear-button,.bt-edit-button,.bt-delete-button,.bt-page-button{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:6px;cursor:pointer;font-weight:700;transition:transform .2s,box-shadow .2s,opacity .2s}.bt-save-button,.bt-clear-button{min-height:40px;padding:0 20px}.bt-save-button{min-width:128px;border:0;color:#fff;background:linear-gradient(135deg,#9868e8,#438cf0);box-shadow:0 10px 20px rgba(93,112,225,.24)}.bt-clear-button{border:1px solid #e8ebf8;color:#626986;background:#fff;box-shadow:0 8px 16px rgba(92,105,190,.1)}.bt-save-button:hover,.bt-clear-button:hover,.bt-edit-button:hover,.bt-delete-button:hover,.bt-page-button:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 12px 20px rgba(92,105,190,.16)}.bt-table-tools{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:12px}.bt-show-control,.bt-search-control{display:inline-flex;align-items:center;gap:8px}.bt-show-control select{width:78px}.bt-search-control input{width:220px}.bt-table-wrap{width:100%;max-height:420px;overflow:auto;border:1px solid #e8ebf8;border-radius:7px;scrollbar-width:thin;scrollbar-color:#b8adff #f5f6ff}.bt-table{width:100%;border-collapse:collapse;color:#303b5e;table-layout:fixed}.bt-table thead{position:sticky;top:0;z-index:1;color:#fff;background:linear-gradient(135deg,#9868e8,#438cf0)}.bt-table th,.bt-table td{padding:12px 10px;border:0;text-align:center;font-size:13px;line-height:1.25;overflow-wrap:anywhere}.bt-table th{font-weight:800}.bt-table tbody tr{border-bottom:1px solid #e8ebf8}.bt-table tbody tr:nth-child(even){background:#f8faff}.bt-table tbody tr:hover{background:#f0edff}.bt-action-column{width:210px}.bt-action-buttons{display:flex;align-items:center;justify-content:center;gap:6px}.bt-edit-button,.bt-delete-button{min-height:36px;padding:0 11px;border:0;color:#fff;font-size:12px}.bt-edit-button{background:linear-gradient(135deg,#7968ef,#5d4fd2)}.bt-delete-button{background:linear-gradient(135deg,#ff6f85,#f54864)}.bt-status-active,.bt-status-inactive{display:inline-block;padding:5px 11px;border-radius:999px;font-size:12px;font-weight:800}.bt-status-active{color:#168263;background:#e7f8f1}.bt-status-inactive{color:#d3455b;background:#fff0f3}.bt-empty{padding:25px!important;color:#667085;font-weight:700}.bt-pagination-bar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-top:14px}.bt-pagination-bar p{margin:0;color:#4e5b7c;font-size:13px;font-weight:700}.bt-pagination-actions{display:flex;gap:8px}.bt-page-button{min-width:42px;min-height:36px;padding:0 13px;border:1px solid #e8ebf8;background:#fff;color:#626986;box-shadow:0 8px 16px rgba(92,105,190,.1)}.bt-page-current{border-color:transparent;color:#fff;background:linear-gradient(135deg,#7968ef,#438cf0)}.bt-page-button:disabled{cursor:not-allowed;opacity:.45}
.bt-watermark{position:absolute;right:36px;top:28px;width:290px;height:230px;border-radius:48% 52% 42% 58%;background:radial-gradient(circle at 76% 16%,rgba(90,224,205,.38),transparent 11%),radial-gradient(circle at 18% 72%,rgba(255,110,139,.16),transparent 17%),linear-gradient(135deg,rgba(167,127,245,.24),rgba(255,218,138,.24));opacity:.4;filter:saturate(85%) brightness(105%) contrast(94%);pointer-events:none;z-index:0}.bt-watermark-road{position:absolute;left:28px;right:25px;bottom:36px;height:40px;border-radius:50%;border-bottom:8px solid #7968ef;transform:rotate(-5deg)}.bt-watermark-road:after{content:"";position:absolute;left:35px;right:35px;bottom:-4px;border-bottom:3px dashed #fff}.bt-watermark-bus{position:absolute;left:64px;top:58px;width:142px;height:92px;border:9px solid #7968ef;border-radius:18px 18px 12px 12px;background:linear-gradient(#fff 0 58%,#aaa0ff 58%);box-shadow:0 18px 28px rgba(121,104,239,.22)}.bt-watermark-bus:before{content:"";position:absolute;left:14px;right:14px;top:13px;height:30px;border-radius:7px;background:linear-gradient(90deg,#dff8f5 0 46%,#7968ef 46% 54%,#dff8f5 54%)}.bt-watermark-bus i{position:absolute;bottom:-18px;width:25px;height:25px;border:7px solid #5d4fd2;border-radius:50%;background:#fff}.bt-watermark-bus i:first-child{left:14px}.bt-watermark-bus i:last-child{right:14px}.bt-watermark-clock{position:absolute;right:18px;top:24px;width:62px;height:62px;display:grid;place-items:center;border-radius:50%;color:#fff;background:linear-gradient(135deg,#5ae0cd,#7968ef);box-shadow:0 12px 20px rgba(67,140,240,.22)}.bt-watermark-clock .bt-icon{width:34px;height:34px}
@media(max-width:1100px){.bt-form{width:100%}.bt-watermark{display:none}}@media(max-width:640px){.bt-card{padding:18px}.bt-form{grid-template-columns:1fr}.bt-form-actions{flex-direction:column}.bt-save-button,.bt-clear-button{width:100%}.bt-table-tools,.bt-pagination-bar{align-items:stretch;flex-direction:column}.bt-search-control input{width:100%}.bt-action-column{width:150px}.bt-action-buttons{flex-wrap:wrap}.bt-pagination-actions{justify-content:flex-end}}
