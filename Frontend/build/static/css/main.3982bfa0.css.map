.bs-page{width:100%;min-width:0;display:grid;gap:18px;padding:2px;color:#202a52}.bs-card{position:relative;width:100%;min-width:0;overflow:hidden;padding:22px 26px;border:1px solid rgba(154,140,255,.28);border-radius:8px;background:rgba(255,255,255,.93);box-shadow:0 14px 32px rgba(92,105,190,.13)}.bs-form-card{min-height:330px;isolation:isolate}.bs-details-card{padding:18px 20px}.bs-section-title{position:relative;z-index:1;width:fit-content;display:flex;align-items:center;gap:12px;margin-bottom:18px}.bs-section-title h3{margin:0;font-size:18px;line-height:1.2;font-weight:800}.bs-heading-icon{width:34px;height:34px;display:grid;place-items:center;border-radius:50%;color:#6654d9;background:#f0edff;box-shadow:0 8px 18px rgba(102,84,217,.16)}.bs-heading-icon .bs-icon{width:19px;height:19px}.bs-icon{width:14px;height:14px;flex:0 0 auto}.bs-form{position:relative;z-index:1;width:min(800px,calc(100% - 360px));display:grid;grid-template-columns:repeat(2,minmax(0,1fr));align-items:end;gap:14px 24px}.bs-field{display:flex;min-width:0;flex-direction:column;gap:6px}.bs-field span,.bs-checkbox-field span,.bs-show-control,.bs-search-control{color:#283354;font-size:13px;font-weight:700}.bs-field input,.bs-field select,.bs-show-control select,.bs-search-control input{min-height:36px;border:1px solid #dfe3f5;border-radius:6px;padding:0 12px;background:#fff;color:#303b5e;font:inherit;outline:none;box-shadow:0 4px 12px rgba(92,105,190,.08);transition:.2s}.bs-field input:focus,.bs-field select:focus,.bs-show-control select:focus,.bs-search-control input:focus{border-color:#7968ef;box-shadow:0 0 0 3px rgba(121,104,239,.16)}.bs-checkbox-field{min-height:36px;display:flex;align-items:center;gap:9px;cursor:pointer}.bs-checkbox-field input{width:17px;height:17px;margin:0;accent-color:#7968ef}.bs-form-actions{grid-column:1/-1;display:flex;gap:14px;margin-top:4px}.bs-save-button,.bs-clear-button,.bs-edit-button,.bs-delete-button,.bs-page-button{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:6px;cursor:pointer;font-weight:700;transition:transform .2s,box-shadow .2s,opacity .2s}.bs-save-button,.bs-clear-button{min-height:40px;padding:0 20px}.bs-save-button{min-width:128px;border:0;color:#fff;background:linear-gradient(135deg,#9868e8,#438cf0);box-shadow:0 10px 20px rgba(93,112,225,.24)}.bs-clear-button{border:1px solid #e8ebf8;color:#626986;background:#fff;box-shadow:0 8px 16px rgba(92,105,190,.1)}.bs-save-button:hover,.bs-clear-button:hover,.bs-edit-button:hover,.bs-delete-button:hover,.bs-page-button:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 12px 20px rgba(92,105,190,.16)}.bs-table-tools{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:12px}.bs-show-control,.bs-search-control{display:inline-flex;align-items:center;gap:8px}.bs-show-control select{width:78px}.bs-search-control input{width:220px}.bs-table-wrap{width:100%;max-height:420px;overflow:auto;border:1px solid #e8ebf8;border-radius:7px;scrollbar-width:thin;scrollbar-color:#b8adff #f5f6ff}.bs-table{width:100%;min-width:880px;border-collapse:collapse;color:#303b5e;table-layout:fixed}.bs-table thead{position:sticky;top:0;z-index:1;color:#fff;background:linear-gradient(135deg,#9868e8,#438cf0)}.bs-table th,.bs-table td{padding:12px 8px;border:0;text-align:center;font-size:13px;line-height:1.25;overflow-wrap:anywhere}.bs-table th{font-weight:800}.bs-table tbody tr{border-bottom:1px solid #e8ebf8}.bs-table tbody tr:nth-child(even){background:#f8faff}.bs-table tbody tr:hover{background:#f0edff}.bs-action-column{width:175px}.bs-action-buttons{display:flex;align-items:center;justify-content:center;gap:6px}.bs-edit-button,.bs-delete-button{min-height:36px;padding:0 9px;border:0;color:#fff;font-size:12px}.bs-edit-button{background:linear-gradient(135deg,#7968ef,#5d4fd2)}.bs-delete-button{background:linear-gradient(135deg,#ff6f85,#f54864)}.bs-status-active,.bs-status-inactive{display:inline-block;padding:5px 11px;border-radius:999px;font-size:12px;font-weight:800}.bs-status-active{color:#168263;background:#e7f8f1}.bs-status-inactive{color:#d3455b;background:#fff0f3}.bs-empty{padding:25px!important;color:#667085;font-weight:700}.bs-pagination-bar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-top:14px}.bs-pagination-bar p{margin:0;color:#4e5b7c;font-size:13px;font-weight:700}.bs-pagination-actions{display:flex;gap:8px}.bs-page-button{min-width:42px;min-height:36px;padding:0 13px;border:1px solid #e8ebf8;background:#fff;color:#626986;box-shadow:0 8px 16px rgba(92,105,190,.1)}.bs-page-current{border-color:transparent;color:#fff;background:linear-gradient(135deg,#7968ef,#438cf0)}.bs-page-button:disabled{cursor:not-allowed;opacity:.45}
.bs-watermark{position:absolute;right:36px;top:42px;width:290px;height:230px;border-radius:48% 52% 42% 58%;background:radial-gradient(circle at 76% 16%,rgba(90,224,205,.38),transparent 11%),radial-gradient(circle at 18% 72%,rgba(255,110,139,.16),transparent 17%),linear-gradient(135deg,rgba(167,127,245,.24),rgba(255,218,138,.24));opacity:.4;filter:saturate(85%) brightness(105%) contrast(94%);pointer-events:none;z-index:0}.bs-watermark-route{position:absolute;left:28px;right:24px;bottom:42px;height:72px;border-radius:50%;border-bottom:9px solid #7968ef;transform:rotate(-8deg)}.bs-watermark-route:after{content:"";position:absolute;left:42px;right:35px;bottom:-5px;border-bottom:3px dashed #fff}.bs-watermark-pin{position:absolute;right:42px;top:28px;width:82px;height:82px;color:#7968ef}.bs-watermark-pin .bs-icon{width:82px;height:82px;filter:drop-shadow(0 12px 10px rgba(121,104,239,.2))}.bs-watermark-bus{position:absolute;left:49px;top:84px;width:120px;height:72px;border:8px solid #7968ef;border-radius:16px 16px 10px 10px;background:linear-gradient(#fff 0 58%,#aaa0ff 58%);box-shadow:0 18px 28px rgba(121,104,239,.22)}.bs-watermark-bus:before{content:"";position:absolute;left:12px;right:12px;top:11px;height:24px;border-radius:6px;background:#dff8f5}.bs-watermark-bus i{position:absolute;bottom:-16px;width:22px;height:22px;border:6px solid #5d4fd2;border-radius:50%;background:#fff}.bs-watermark-bus i:first-child{left:12px}.bs-watermark-bus i:last-child{right:12px}
@media(max-width:1100px){.bs-form{width:100%}.bs-watermark{display:none}}@media(max-width:640px){.bs-card{padding:18px}.bs-form{grid-template-columns:1fr}.bs-form-actions{flex-direction:column}.bs-save-button,.bs-clear-button{width:100%}.bs-table-tools,.bs-pagination-bar{align-items:stretch;flex-direction:column}.bs-search-control input{width:100%}.bs-pagination-actions{justify-content:flex-end}}
