}

.bank-field input,
.bank-field select,
.bank-show-control select,
.bank-search-control input{
  border-color:#d2d7d4;
  background:#fffdf8;
  color:#20303b;
}

.bank-field input:focus,
.bank-field select:focus,
.bank-show-control select:focus,
.bank-search-control input:focus{
  border-color:#d87457;
  box-shadow:0 0 0 3px rgba(216,116,87,.16);
}

.bank-save-button{
  background:linear-gradient(135deg,#d87457,#b94f46);
  box-shadow:0 8px 18px rgba(185,79,70,.25);
}

.bank-clear-button,
.bank-cancel-button{
  background:linear-gradient(135deg,#335565,#244f58);
}

.bank-edit-button{
  background:linear-gradient(135deg,#f0bb68,#d3993a);
  color:#17313e;
}

.bank-delete-button{
  background:linear-gradient(135deg,#d87457,#b94f46);
}

.bank-table{
  color:#20303b;
}

.bank-table tbody tr{
  border-bottom-color:#e4dac8;
}

.bank-table tbody tr:nth-child(even){
  background:#fff8ed;
}

.bank-table tbody tr:hover{
  background:#f7efe1;
}

/* Purple-blue configuration screen theme */
.bank-account-page {
  height: auto;
  min-height: 560px;
  grid-template-rows: auto auto;
  gap: 18px;
  overflow: visible;
  padding: 2px;
}

.bank-card {
  position: relative;
  border: 1px solid rgba(155, 126, 255, 0.18);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14px 35px rgba(74, 88, 190, 0.13);
}

.bank-form-card {
  min-height: 290px;
  padding: 22px 26px;
  isolation: isolate;
}

.bank-details-card {
  min-height: 0;
  padding: 18px 20px;
  display: flex;
  flex-direction: column;
}

.bank-section-title {
  position: relative;
  z-index: 1;
  width: fit-content;
  min-height: auto;
  margin-bottom: 18px;
  padding: 0;
  color: #18244a;
  background: transparent;
}

.bank-section-title h3 {
  font-size: 18px;
}

.bank-heading-icon {
  width: 34px;
  height: 34px;
  padding: 8px;
  border-radius: 50%;
  color: #7b5cff;
  background: #f1edff;
  box-shadow: 0 8px 18px rgba(123, 92, 255, 0.16);
}

.bank-form {
  position: relative;
  z-index: 1;
  width: min(800px, calc(100% - 360px));
  gap: 14px 24px;
}

.bank-field {
  gap: 6px;
}

.bank-field span,
.bank-field label,
.bank-show-control,
.bank-search-control {
  color: #1f2a4d;
  font-size: 13px;
}

.bank-field input,
.bank-field select,
.bank-show-control select,
.bank-search-control input {
  min-height: 36px;
  border-color: #e2e5f3;
  border-radius: 6px;
  background: #ffffff;
  color: #293457;
  box-shadow: 0 4px 12px rgba(91, 103, 168, 0.08);
}

.bank-field input:focus,
.bank-field select:focus,
.bank-show-control select:focus,
.bank-search-control input:focus {
  border-color: #7b5cff;
  box-shadow: 0 0 0 3px rgba(123, 92, 255, 0.16);
}

.bank-form-actions {
  justify-content: flex-start;
  gap: 14px;
  margin-top: 6px;
}

.bank-save-button,
.bank-clear-button,
.bank-cancel-button {
  min-height: 40px;
  border-radius: 6px;
}

.bank-save-button {
  min-width: 118px;
  background: linear-gradient(135deg, #c333d8, #2678ec);
  box-shadow: 0 10px 20px rgba(123, 92, 255, 0.25);
}

.bank-clear-button,
.bank-cancel-button {
  padding: 0 20px;
  color: #746f8c;
  background: #ffffff;
  border: 1px solid #edf0f8;
  box-shadow: 0 8px 16px rgba(91, 103, 168, 0.1);
}

.bank-table-tools {
  margin-bottom: 12px;
}

.bank-table-wrap {
  flex: 0 0 auto;
  min-height: 0;
  max-height: 420px;
  overflow-x: hidden;
  overflow-y: auto;
  border: 1px solid #eef1fb;
  border-radius: 7px;
  scrollbar-width: thin;
  scrollbar-color: #b7a8ff #f4f6ff;
}

.bank-table-wrap::-webkit-scrollbar {
  display: block;
  width: 8px;
  height: 0;
}

.bank-table-wrap::-webkit-scrollbar-track {
  background: #f4f6ff;
}

.bank-table-wrap::-webkit-scrollbar-thumb {
  background: #b7a8ff;
  border-radius: 999px;
}

.bank-table thead {
  position: sticky;
  top: 0;
  z-index: 1;
  background: linear-gradient(90deg, #c333d8, #2678ec);
}

.bank-table th,
.bank-table td {
  padding: 12px 8px;
  font-size: 13px;
  line-height: 1.25;
  white-space: normal;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.bank-table {
  min-width: 0;
  table-layout: fixed;
}

.bank-table th:nth-child(1),
.bank-table td:nth-child(1),
.bank-table th:nth-child(2),
.bank-table td:nth-child(2),
.bank-table th:nth-child(3),
.bank-table td:nth-child(3),
.bank-table th:nth-child(5),
.bank-table td:nth-child(5) {
  width: 13%;
}

.bank-table th:nth-child(4),
.bank-table td:nth-child(4),
.bank-table th:nth-child(6),
.bank-table td:nth-child(6),
.bank-table th:nth-child(7),
.bank-table td:nth-child(7) {
  width: 10%;
}

.bank-table .bank-action-column {
  width: 18%;
}

.bank-table tbody tr {
  border-bottom-color: #eef1fb;
}

.bank-table tbody tr:nth-child(even) {
  background: #fbfcff;
}

.bank-table tbody tr:hover {
  background: #f4f1ff;
}

.bank-pagination-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-top: 14px;
}

.bank-pagination-bar p {
  margin: 0;
  color: #53607d;
  font-size: 13px;
  font-weight: 700;
}

.bank-pagination-actions {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.bank-page-button {
  min-width: 42px;
  min-height: 36px;
  padding: 0 13px;
  border: 1px solid #edf0f8;
  border-radius: 8px;
  background: #ffffff;
  color: #6c7190;
  font-weight: 800;
  cursor: pointer;
  box-shadow: 0 8px 16px rgba(91, 103, 168, 0.1);
  transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s;
}

.bank-page-button:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 12px 20px rgba(91, 103, 168, 0.16);
}

.bank-page-button:disabled {
  cursor: not-allowed;
  opacity: 0.45;
}

.bank-page-current {
  border-color: transparent;
  color: #ffffff;
  background: linear-gradient(135deg, #7b5cff, #543bd7);
  box-shadow: 0 10px 20px rgba(123, 92, 255, 0.25);
}

.bank-edit-button {
  background: linear-gradient(135deg, #7b5cff, #543bd7);
  color: #ffffff;
}

.bank-delete-button {
  background: linear-gradient(135deg, #ff4d6d, #f13755);
}

.bank-hero-art {
  position: absolute;
  right: 36px;
  top: 28px;
  width: 290px;
  height: 230px;
  border-radius: 48% 52% 42% 58%;
  background: radial-gradient(circle at 76% 16%, rgba(68, 226, 202, 0.42), transparent 11%),
    radial-gradient(circle at 18% 72%, rgba(255, 88, 126, 0.18), transparent 17%),
    linear-gradient(135deg, rgba(197, 51, 216, 0.16), rgba(255, 210, 120, 0.24));
  z-index: 0;
  pointer-events: none;
}

.bank-art-building {
  position: absolute;
  left: 82px;
  top: 44px;
  width: 126px;
  height: 108px;
  border-radius: 12px;
  border: 10px solid #7b5cff;
  background: #ffffff;
  box-shadow: 0 18px 28px rgba(123, 92, 255, 0.24);
}

.bank-art-building::before {
  content: "";
  position: absolute;
  left: 26px;
  right: 26px;
  top: -34px;
  height: 40px;
  background: #7b5cff;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.bank-art-building::after {
  content: "";
  position: absolute;
  inset: 26px 15px;
  background: repeating-linear-gradient(90deg, #a999ff 0 11px, transparent 11px 25px);
}

.bank-art-card {
  position: absolute;
  width: 82px;
  height: 50px;
  border-radius: 10px;
  background: linear-gradient(135deg, #7b5cff, #2678ec);
  box-shadow: 0 12px 20px rgba(38, 120, 236, 0.25);
}

.bank-art-card-one {
  left: 28px;
  bottom: 38px;
}

.bank-art-card-two {
  right: 18px;
  bottom: 32px;
  background: linear-gradient(135deg, #44e2ca, #7b5cff);
}

@media (max-width: 1280px) {
  .bank-table th,
  .bank-table td {
    padding: 10px 6px;
    font-size: 12px;
  }

  .bank-edit-button,
  .bank-delete-button {
    min-width: 58px;
    padding: 0 7px;
    font-size: 12px;
  }

  .bank-table .bank-action-column {
    width: 16%;
  }
}

@media (max-width: 640px) {
  .bank-pagination-bar {
    align-items: stretch;
    flex-direction: column;
  }

  .bank-pagination-actions {
    justify-content: flex-end;
  }
}

@media (max-width: 1100px) {
  .bank-account-page {
    height: auto;
    overflow: visible;
  }

  .bank-form {
    width: 100%;
  }

  .bank-hero-art {
    display: none;
  }
}

