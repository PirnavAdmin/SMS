/* ==========================================
   MAIN PAGE
========================================== */

.bank-account-page{
  width:100%;
  max-width:100%;
  min-width:0;
  display:grid;
  gap:28px;
  color:#10213f;
  overflow-x:hidden;
}

/* ==========================================
   CARD
========================================== */

.bank-card{
  width:100%;
  max-width:100%;
  min-width:0;
  overflow:hidden;
  padding:28px;
  border:1px solid #d7e0ec;
  border-radius:12px;
  background:#ffffff;
  box-shadow:0 8px 20px rgba(15,34,60,.08);
}

/* ==========================================
   HEADER
========================================== */

.bank-section-title{
  min-height:56px;
  display:flex;
  align-items:center;
  gap:12px;
  margin-bottom:26px;
  padding:0 20px;
  border-radius:8px;
  color:#fff;
  background:linear-gradient(
    90deg,
    #101a35,
    #28449a
  );
}

.bank-section-title h3{
  margin:0;
  font-size:20px;
  line-height:1.2;
  font-weight:800;
}

.bank-heading-icon{
  width:22px;
  height:22px;
  flex:0 0 auto;
  color:#fff;
}

/* ==========================================
   FORM
========================================== */

.bank-form{
  display:grid;
  grid-template-columns:
  repeat(3,minmax(0,1fr));
  gap:24px;
}

.bank-field{
  min-width:0;
  display:flex;
  flex-direction:column;
  gap:10px;
}

/* LEFT ALIGN LABELS */

.bank-field span,
.bank-field label{
  text-align:left;
  font-size:15px;
  font-weight:700;
  color:#11254a;
}

.bank-field input,
.bank-field select{
  width:100%;
  min-height:48px;
  border:1px solid #c8d4e5;
  border-radius:8px;
  padding:0 14px;
  background:#fff;
  color:#17233e;
  font-size:15px;
  outline:none;
  transition:.3s;
}

.bank-field input:focus,
.bank-field select:focus{
  border-color:#416feb;
  box-shadow:
  0 0 0 3px rgba(65,111,235,.15);
}

/* ==========================================
   BUTTON AREA
========================================== */

.bank-form-actions{
  grid-column:1/-1;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:15px;
  margin-top:10px;
}

/* ==========================================
   GLASS BUTTONS
========================================== */

.bank-save-button,
.bank-clear-button,
.bank-cancel-button,
.bank-edit-button,
.bank-delete-button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  border:none;
  border-radius:10px;
  cursor:pointer;
  color:#fff;
  font-weight:700;

  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);

  transition:.35s;
}

/* SAVE */

.bank-save-button{
  min-width:180px;
  min-height:50px;
  background:
  linear-gradient(
    135deg,
    rgba(72,120,240,.9),
    rgba(40,68,154,.9)
  );

  box-shadow:
  0 8px 18px rgba(72,120,240,.25);
}

/* CANCEL */

.bank-cancel-button{
  min-height:50px;
  padding:0 25px;

  background:
  linear-gradient(
    135deg,
    rgba(107,114,128,.9),
    rgba(75,85,99,.9)
  );
}

.bank-clear-button{
  min-height:50px;
  padding:0 25px;

  background:
  linear-gradient(
    135deg,
    rgba(107,114,128,.9),
    rgba(75,85,99,.9)
  );
}

/* EDIT */

.bank-edit-button{
  min-height:36px;
  min-width:72px;
  padding:0 10px;
  font-size:13px;

  background:
  linear-gradient(
    135deg,
    rgba(245,166,35,.95),
    rgba(255,193,7,.9)
  );
}

/* DELETE */

.bank-delete-button{
  min-height:36px;
  min-width:86px;
  padding:0 10px;
  font-size:13px;

  background:
  linear-gradient(
    135deg,
    rgba(229,68,68,.95),
    rgba(220,38,38,.9)
  );
}

/* GLOSS EFFECT */

.bank-save-button:hover,
.bank-clear-button:hover,
.bank-cancel-button:hover,
.bank-edit-button:hover,
.bank-delete-button:hover{
  transform:
  translateY(-2px);

  box-shadow:
  0 12px 24px rgba(0,0,0,.18);

  background-position:right center;
}

.bank-button-icon{
  width:14px;
  height:14px;
  flex:0 0 auto;
}

/* ==========================================
   TABLE CARD
========================================== */

.bank-details-card{
  padding-bottom:20px;
}

.bank-table-tools{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  margin-bottom:18px;
}

.bank-show-control,
.bank-search-control{
  display:inline-flex;
  align-items:center;
  gap:8px;
  color:#11254a;
  font-size:15px;
  font-weight:700;
}

.bank-show-control select,
.bank-search-control input{
  min-height:40px;
  border:1px solid #c8d4e5;
  border-radius:8px;
  padding:0 12px;
  background:#fff;
  color:#17233e;
  font:inherit;
  outline:none;
  transition:.3s;
}

.bank-show-control select{
  width:88px;
}

.bank-search-control input{
  width:220px;
}

.bank-show-control select:focus,
.bank-search-control input:focus{
  border-color:#416feb;
  box-shadow:
  0 0 0 3px rgba(65,111,235,.15);
}

/* ==========================================
   TABLE WRAPPER
========================================== */

.bank-table-wrap{
  width:100%;
  max-width:100%;
  overflow-x:hidden;
  scrollbar-width:none;
  -ms-overflow-style:none;
}

.bank-table-wrap::-webkit-scrollbar{
  display:none;
}

/* ==========================================
   TABLE
========================================== */

.bank-table{
  width:100%;
  min-width:0;
  border-collapse:collapse;
  color:#162343;
  table-layout:fixed;
}

/* HEADER */

.bank-table thead{
  background:#28449a;
  color:#fff;
}

.bank-table th{
  padding:14px 8px;
  font-weight:700;
  text-align:center;
  font-size:14px;
  line-height:1.25;
  overflow-wrap:anywhere;
}

/* BODY */

.bank-table td{
  padding:14px 8px;
  text-align:center;
  font-size:14px;
  line-height:1.25;
  overflow-wrap:anywhere;
}

.bank-table tbody tr{
  border-bottom:1px solid #e5e7eb;
}

.bank-table tbody tr:nth-child(even){
  background:#f8fbff;
}

.bank-table tbody tr:hover{
  background:#eef5ff;
}

/* REMOVE BLACK LINES */

.bank-table th,
.bank-table td{
  border:none;
}

/* ==========================================
   ACTION BUTTONS
========================================== */

.bank-action-buttons{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:6px;
  flex-wrap:nowrap;
  white-space:nowrap;
}

.bank-table .bank-action-column{
  width:165px;
}

/* ==========================================
   EMPTY DATA
========================================== */

.bank-empty{
  padding:25px;
  text-align:center;
  color:#667085;
  font-weight:700;
}

/* ==========================================
   RESPONSIVE
========================================== */

@media(max-width:1100px){

  .bank-form{
    grid-template-columns:
    repeat(2,minmax(0,1fr));
  }

}

@media(max-width:768px){

  .bank-card{
    padding:18px;
  }

  .bank-section-title{
    min-height:50px;
    padding:0 14px;
    margin-bottom:20px;
  }

  .bank-section-title h3{
    font-size:18px;
  }

  .bank-form{
    grid-template-columns:1fr;
  }

  .bank-form-actions{
    flex-direction:column;
  }

  .bank-table-tools{
    flex-direction:column;
    align-items:stretch;
  }

  .bank-search-control input{
    width:100%;
  }

  .bank-save-button,
  .bank-clear-button,
  .bank-cancel-button{
    width:100%;
  }

  .bank-table th,
  .bank-table td{
    padding:12px 6px;
    font-size:13px;
  }
}

/* School Manager Admin Hub palette */
.bank-card{
  border-color:#d3c5af;
  background:#fffdf8;
  box-shadow:0 18px 35px rgba(35,63,74,.08);
}

